{
  "@timestamp": {
    "$resolver": "timestamp",
    "pattern": {
      "format": "yyyy-MM-dd'T'HH:mm:ss.SSSXXX",
      "timeZone": "UTC"
    }
  },
  "level": {
    "$resolver": "level",
    "field": "name"
  },
  "logger": {
    "$resolver": "logger",
    "field": "name"
  },
  "thread": {
    "$resolver": "thread",
    "field": "name"
  },
  "message": {
    "$resolver": "message",
    "stringified": true
  },
  "trace_id": {
    "$resolver": "mdc",
    "key": "traceId"
  },
  "span_id": {
    "$resolver": "mdc",
    "key": "spanId"
  },
  "user_id": {
    "$resolver": "mdc",
    "key": "userId"
  },
  "client_ip": {
    "$resolver": "mdc",
    "key": "clientIp"
  },
  "request": {
    "$resolver": "mdc",
    "key": "requestInfo"
  },
  "route": {
    "$resolver": "mdc",
    "key": "routePattern"
  },
  "http_status": {
    "$resolver": "mdc",
    "key": "status"
  },
  "elapsed_ms": {
    "$resolver": "mdc",
    "key": "elapsed"
  },
  "error_type": {
    "$resolver": "exception",
    "field": "className"
  },
  "error_message": {
    "$resolver": "exception",
    "field": "message"
  }
}
