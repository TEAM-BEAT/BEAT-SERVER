<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="INFO">
    <Properties>
        <Property name="LOG_PATTERN">
            %style{%d{yyyy-MM-dd HH:mm:ss,SSS}}{blue} %highlight{[%-5p]}{FATAL=bg_red, ERROR=red, WARN=yellow, INFO=green, DEBUG=bright_blue, TRACE=cyan} [%t] %style{[traceId=%equals{%X{traceId}}{}{NO_TRACE}]}{cyan}%style{%replace{%X{spanId}}{^(.+)$}{ [spanId=$1]}}{bright_blue} %style{[userId=%equals{%X{userId}}{}{GUEST}]}{yellow} %style{[clientIp=%equals{%X{clientIp}}{}{UNKNOWN}]}{magenta} %style{[request=%equals{%X{requestInfo}}{}{NO_REQUEST}]}{green} %style{[route=%equals{%X{routePattern}}{}{NO_ROUTE}]}{bright_green} %style{[%c{1}.%M():%L]}{BRIGHT_BLACK} - %m%n
        </Property>
    </Properties>

    <Appenders>
        <!--
            ConsoleAppender: 레이아웃을 BEAT_LOG_FORMAT 환경변수로 전환한다(전환 로직은 여기 한 곳).
              · 기본(로컬 IntelliJ Run, env 없음): PatternLayout 컬러 plain text — 개발자 무설정.
              · BEAT_LOG_FORMAT=json(배포 컨테이너, ansible app_container_env 주입): JsonTemplateLayout.
            dev·test 프로파일이 공용으로 참조한다. (Select: 첫 매칭 arbiter만 채택, 미매칭 시 DefaultArbiter)
        -->
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <Select>
                <EnvironmentArbiter propertyName="BEAT_LOG_FORMAT" propertyValue="json">
                    <JsonTemplateLayout eventTemplateUri="classpath:beat-log-event-template.json"/>
                </EnvironmentArbiter>
                <DefaultArbiter>
                    <PatternLayout pattern="${LOG_PATTERN}" disableAnsi="${env:LOG_DISABLE_ANSI:-false}"/>
                </DefaultArbiter>
            </Select>
        </Console>

        <!-- prod 전용: 항상 JSON. env 주입과 무관하게 관측 포맷을 보장(fail-safe). -->
        <Console name="JsonConsoleAppender" target="SYSTEM_OUT">
            <JsonTemplateLayout eventTemplateUri="classpath:beat-log-event-template.json"/>
        </Console>

        <!--
            SentryAppender: minimumEventLevel=ERROR → com.beat 로거에서만 참조.
            access logger 와 Root 는 SentryAppender 미참조로 이중 캡처 / 서드파티 ERROR 오염을 방지한다.
        -->
        <Sentry name="SentryAppender" minimumBreadcrumbLevel="INFO" minimumEventLevel="ERROR" minimumLevel="INFO"/>
    </Appenders>

    <Loggers>
        <springProfile name="prod">
            <Logger name="com.beat.observability.logging.access" level="INFO" additivity="false">
                <AppenderRef ref="JsonConsoleAppender"/>
            </Logger>
            <Logger name="com.beat" level="INFO" additivity="false">
                <AppenderRef ref="JsonConsoleAppender"/>
                <AppenderRef ref="SentryAppender"/>
            </Logger>
            <Root level="INFO">
                <AppenderRef ref="JsonConsoleAppender"/>
            </Root>
        </springProfile>

        <!--
            dev 는 배포·로컬 공용 단일 프로파일. 콘솔 포맷 전환은 ConsoleAppender 가 BEAT_LOG_FORMAT 으로 처리하므로
            여기서는 그냥 ConsoleAppender 만 참조한다(로컬=plain text, 배포 dev=JSON 자동 전환).
            DB·앱 설정은 dev 그대로 두고 로그 표현만 바뀌므로 별도 local 프로파일 불필요.
        -->
        <springProfile name="dev">
            <Logger name="com.beat.observability.logging.access" level="INFO" additivity="false">
                <AppenderRef ref="ConsoleAppender"/>
            </Logger>
            <Logger name="com.beat" level="INFO" additivity="false">
                <AppenderRef ref="ConsoleAppender"/>
                <AppenderRef ref="SentryAppender"/>
            </Logger>
            <Root level="INFO">
                <AppenderRef ref="ConsoleAppender"/>
            </Root>
        </springProfile>

        <springProfile name="test">
            <Root level="INFO">
                <AppenderRef ref="ConsoleAppender"/>
            </Root>
        </springProfile>
    </Loggers>
</Configuration>
