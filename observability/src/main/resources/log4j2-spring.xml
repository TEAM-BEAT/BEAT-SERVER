<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="INFO">
    <Properties>
        <Property name="LOG_PATTERN">
            %style{%d{yyyy-MM-dd HH:mm:ss,SSS}}{blue} %highlight{[%-5p]}{FATAL=bg_red, ERROR=red, WARN=yellow, INFO=green, DEBUG=bright_blue, TRACE=cyan} [%t] %style{[traceId=%equals{%X{traceId}}{}{NO_TRACE}]}{cyan}%notEmpty{ %style{[spanId=%X{spanId}]}{bright_blue}} %style{[userId=%equals{%X{userId}}{}{GUEST}]}{yellow} %style{[clientIp=%equals{%X{clientIp}}{}{UNKNOWN}]}{magenta} %style{[request=%equals{%X{requestInfo}}{}{NO_REQUEST}]}{green} %style{[route=%equals{%X{routePattern}}{}{NO_ROUTE}]}{bright_green} %style{[%c{1}.%M():%L]}{BRIGHT_BLACK} - %m%n
        </Property>
    </Properties>

    <Appenders>
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}" disableAnsi="${env:LOG_DISABLE_ANSI:-false}"/>
        </Console>

        <Console name="JsonConsoleAppender" target="SYSTEM_OUT">
            <JsonTemplateLayout eventTemplateUri="classpath:beat-log-event-template.json"/>
        </Console>

        <!--
            SentryAppender: minimumEventLevel=ERROR → com.beat 로거에서만 참조.
            access logger 와 Root 는 SentryAppender 미참조로 이중 캡처 / 서드파티 ERROR 오염을 방지한다.
        -->
        <Sentry name="SentryAppender" minimumBreadcrumbLevel="INFO" minimumEventLevel="ERROR" minimumLevel="INFO"/>
    </Appenders>

    <Loggers>
        <springProfile name="prod">
            <Logger name="com.beat.observability.logging.access" level="INFO" additivity="false">
                <AppenderRef ref="JsonConsoleAppender"/>
            </Logger>
            <Logger name="com.beat" level="INFO" additivity="false">
                <AppenderRef ref="JsonConsoleAppender"/>
                <AppenderRef ref="SentryAppender"/>
            </Logger>
            <Root level="INFO">
                <AppenderRef ref="JsonConsoleAppender"/>
            </Root>
        </springProfile>

        <springProfile name="dev">
            <Logger name="com.beat.observability.logging.access" level="INFO" additivity="false">
                <AppenderRef ref="ConsoleAppender"/>
            </Logger>
            <Logger name="com.beat" level="INFO" additivity="false">
                <AppenderRef ref="ConsoleAppender"/>
                <AppenderRef ref="SentryAppender"/>
            </Logger>
            <Root level="INFO">
                <AppenderRef ref="ConsoleAppender"/>
            </Root>
        </springProfile>

        <springProfile name="test">
            <Root level="INFO">
                <AppenderRef ref="ConsoleAppender"/>
            </Root>
        </springProfile>
    </Loggers>
</Configuration>
