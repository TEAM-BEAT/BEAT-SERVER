# All upstreams (backend, admin_backend, actuator) are managed via generated fragments.
# Seeds are created by nginx_base_config; deploys overwrite with real values via upsert-upstream.

# BEGIN BEAT MANAGED GENERATED UPSTREAM INCLUDES
include {{ nginx_generated_include_dir }}/upstreams/*.conf;
# END BEAT MANAGED GENERATED UPSTREAM INCLUDES

{% macro render_scanner_policy() -%}
{% if nginx_base_config_scanner_block_enabled | default(true) | bool %}
    # BEAT scanner/bot terminal policy. Keep exact/^~ locations before generated routes.
{% for path in nginx_base_config_scanner_exact_paths | default([]) %}
    location = {{ path }} {
        return {{ nginx_base_config_scanner_block_status | default(404) }};
    }
{% endfor %}
{% for prefix in nginx_base_config_scanner_prefix_paths | default([]) %}
    location ^~ {{ prefix }} {
        return {{ nginx_base_config_scanner_block_status | default(404) }};
    }
{% endfor %}
    location ~ "^/\.env(?:\.[A-Za-z0-9_-]{1,32})?$" {
        return {{ nginx_base_config_scanner_block_status | default(404) }};
    }
{% endif %}
{%- endmacro %}

log_format {{ nginx_access_log_format_name }} 'traceId=$request_id clientIp=$remote_addr request="$request" '
    'status=$status bytes=$body_bytes_sent referer="$http_referer" userAgent="$http_user_agent" '
    'xForwardedFor="$http_x_forwarded_for" requestTime=$request_time';

# W3C traceparent 합성: nginx $request_id(32 hex = 16 byte) 를 그대로 trace-id 로 사용해
# nginx access log / app log(trace_id) / Tempo trace 를 단일 ID 로 묶는다.
# 포맷: version(00) - traceId(32hex) - parentSpanId(16hex) - flags(2hex)
#   - parentSpanId: request_id 앞 16자 재사용. nginx 는 자체 span 을 export 하지 않으므로
#     이 부모 span 은 Tempo 에 실체가 없는 seed(phantom parent)일 뿐, 앱 span 은 정상 export 된다.
#   - flags=01(sampled): 현재 앱은 head sampling 100% 라 무충돌. 추후 앱 head sampling 비율을
#     낮추면 nginx 가 항상 01 을 강제해 불일치가 생기므로, 그때는 split_clients 등으로 01/00 을 분배할 것.
map $request_id $trace_parent {
    "~^(?<span_seed>.{16})" "00-$request_id-$span_seed-01";
    default                 "00-$request_id-0000000000000001-01";
}

server {
    listen 80;
    server_name {{ nginx_server_name }};
    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

{{ render_scanner_policy() }}

    access_log /var/log/nginx/access.log {{ nginx_access_log_format_name }};

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name {{ nginx_server_name }};

    ssl_certificate /etc/letsencrypt/live/{{ letsencrypt_cert_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ letsencrypt_cert_name }}/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    underscores_in_headers on;

{{ render_scanner_policy() }}

    # BEGIN BEAT MANAGED GENERATED ROUTE INCLUDES
    include {{ nginx_generated_include_dir }}/routes/*.conf;
    # END BEAT MANAGED GENERATED ROUTE INCLUDES

    location {{ actuator_path }}/ {
        proxy_pass http://{{ actuator_upstream_name | default('actuator') }};
        proxy_redirect off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Request-ID $request_id;
{% if actuator_allow_cidrs is defined and actuator_allow_cidrs %}
{% for cidr in actuator_allow_cidrs %}
        allow {{ cidr }};
{% endfor %}
        deny all;
{% else %}
        deny all;
{% endif %}
    }

    access_log /var/log/nginx/access.log {{ nginx_access_log_format_name }};

    location / {
        proxy_pass http://{{ backend_upstream_name | default('backend') }};
        proxy_redirect off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Request-ID $request_id;
        proxy_set_header traceparent $trace_parent;
    }
}
